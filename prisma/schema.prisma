generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLAYER
  ADMIN
}

enum SeasonStatus {
  POLLING
  ACTIVE
  COMPLETED
}

enum GameStatus {
  PENDING
  CONFIRMED
  DISPUTED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  avatar       String?
  role         Role     @default(PLAYER)
  banned       Boolean  @default(false)
  defaultDeckId String?
  createdAt    DateTime @default(now())

  decks         Deck[]         @relation("UserDecks")
  defaultDeck   Deck?          @relation("UserDefaultDeck", fields: [defaultDeckId], references: [id], onDelete: SetNull)
  pollVotes     PollVote[]
  gamePlayers   GamePlayer[]
  gamesCreated  Game[]         @relation("GameCreator")
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  bugReports    BugReport[]
}

model Deck {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  commander           String
  externalLink        String?
  validatedPriceCents Int?
  archived            Boolean  @default(false)
  createdAt           DateTime @default(now())

  user            User         @relation("UserDecks", fields: [userId], references: [id], onDelete: Cascade)
  defaultForUsers User[]       @relation("UserDefaultDeck")
  gamePlayers     GamePlayer[]
}

model Season {
  id        String       @id @default(cuid())
  name      String
  budgetCap Int?
  status    SeasonStatus @default(POLLING)
  createdAt DateTime     @default(now())

  pollVotes PollVote[]
  games     Game[]
}

model PollVote {
  id       String @id @default(cuid())
  seasonId String
  userId   String
  choice   Int

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
}

model Game {
  id          String     @id @default(cuid())
  seasonId    String
  createdById String
  status      GameStatus @default(PENDING)
  lastReminderAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime   @default(now())

  season    Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  createdBy User         @relation("GameCreator", fields: [createdById], references: [id], onDelete: Cascade)
  players   GamePlayer[]
}

model GamePlayer {
  id        String  @id @default(cuid())
  gameId    String
  userId    String
  deckId    String?
  isWinner  Boolean @default(false)
  confirmed Boolean @default(false)

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck? @relation(fields: [deckId], references: [id], onDelete: SetNull)

  @@unique([gameId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  summary    String
  details    Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String?
  description String
  pagePath    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}
